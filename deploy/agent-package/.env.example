# URL backend (https://domain или https://ip)
BASE_URL=https://monitor.example.com

# Тот же токен, что и REGISTRATION_TOKEN в backend
REGISTRATION_TOKEN=CHANGE_ME_REGISTRATION_TOKEN

# Интервал heartbeat (секунд), безопасный диапазон 5-10
AGENT_INTERVAL=5

# INFO / DEBUG / WARNING / ERROR
LOG_LEVEL=INFO

# true в production; false только для self-signed dev стенда
VERIFY_TLS=true

# Белый список команд для task_type=run_command
ALLOWED_COMMANDS=uptime,df -h,free -m,uname -a
